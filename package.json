{
  "name": "nova-pdf-reader",
  "version": "1.0.0",
  "description": "Modern Electron PDF reader with CUDA-accelerated streaming TTS via Kokoro",
  "main": "dist/main/main/index.js",
  "author": "J. Michaels",
  "license": "MIT",
  "homepage": "https://github.com/sanchez314c/nova-pdf-reader",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sanchez314c/nova-pdf-reader.git"
  },
  "bugs": {
    "url": "https://github.com/sanchez314c/nova-pdf-reader/issues"
  },
  "keywords": [
    "pdf",
    "pdf-reader",
    "electron",
    "react",
    "tts",
    "text-to-speech",
    "kokoro",
    "desktop"
  ],
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "concurrently -k \"pnpm dev:vite\" \"pnpm dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on http://localhost:54450 && NODE_ENV=development electron . --inspect --no-sandbox --dev --enable-transparent-visuals",
    "start": "./scripts/start-app.sh",
    "build": "pnpm build:vite && pnpm build:electron",
    "build:vite": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "dist": "pnpm build && electron-builder --linux",
    "dist:deb": "pnpm build && electron-builder --linux deb",
    "dist:appimage": "pnpm build && electron-builder --linux AppImage",
    "dist:all": "pnpm build && electron-builder --linux --win --mac",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf dist out node_modules",
    "postinstall": "electron-builder install-app-deps",
    "tts:setup": "bash tts-server/setup.sh",
    "tts:start": "bash tts-server/start.sh",
    "tts:stop": "pkill -f 'python.*server.py' || true"
  },
  "dependencies": {
    "pdfjs-dist": "^4.2.67",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "postcss": "^8.4.47",
    "rimraf": "^6.0.0",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^2.0.0",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.sanchez314c.nova-pdf-reader",
    "productName": "Nova PDF Reader",
    "directories": {
      "output": "dist-electron",
      "buildResources": "resources"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "resources/icons",
      "category": "Office",
      "maintainer": "J. Michaels"
    },
    "deb": {
      "depends": []
    },
    "appImage": {
      "artifactName": "NovaPDFReader-${version}.AppImage"
    }
  }
}
